<ui:FluentWindow
    x:Class="VoiceAgent.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="VozPluma"
    Width="500" Height="680" MinWidth="420" MinHeight="520"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <!-- Anillo pulsante del estado "grabando" -->
        <Storyboard x:Key="Pulso" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Anillo"
                             Storyboard.TargetProperty="Opacity"
                             From="0.5" To="0" Duration="0:0:1.1" />
            <DoubleAnimation Storyboard.TargetName="AnilloScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.6" Duration="0:0:1.1" />
            <DoubleAnimation Storyboard.TargetName="AnilloScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.6" Duration="0:0:1.1" />
        </Storyboard>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="VozPluma" ShowMaximize="False" />

        <!-- Contenido con ancho máximo para que no se disperse en ventanas grandes -->
        <Grid Grid.Row="1" Margin="24,0,24,16" MaxWidth="560">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Cabecera compacta -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="VozPluma" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="Transcripción local — tu voz no sale de este equipo"
                               FontSize="12" Margin="0,2,0,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <ui:Button x:Name="BotonWidget" Padding="10,6" FontSize="12"
                               Margin="0,0,8,0" IsEnabled="False"
                               Click="BotonWidget_Click"
                               ToolTip="Widget flotante: dicta en cualquier aplicación">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PictureInPicture24" FontSize="14"
                                           Margin="0,0,6,0" />
                            <TextBlock Text="Modo widget" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="BotonAjustes" Padding="8,6"
                               Click="BotonAjustes_Click" ToolTip="Ajustes">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="14" />
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!-- Selectores con etiqueta -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Modelo" FontSize="12" Margin="4,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="ModeloCombo" SelectionChanged="Selector_Changed">
                        <ComboBoxItem Content="Whisper turbo (int8)" IsSelected="True" />
                        <ComboBoxItem Content="Nemotron 3.5 (0.6B)" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Idioma" FontSize="12" Margin="4,0,0,4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="IdiomaCombo" SelectionChanged="Selector_Changed" />
                </StackPanel>
            </Grid>

            <!-- Historial -->
            <Grid Grid.Row="2">
                <ScrollViewer x:Name="Scroll" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="Lista" />
                </ScrollViewer>
                <TextBlock x:Name="Placeholder"
                           Text="Pulsa el micrófono y habla&#10;La transcripción aparecerá aquí"
                           TextAlignment="Center" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </Grid>

            <!-- Zona inferior fija: estado + micrófono -->
            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                <TextBlock x:Name="Estado" Text="Iniciando…"
                           FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <Grid Height="88" HorizontalAlignment="Center">
                    <Ellipse x:Name="Anillo" Width="72" Height="72" Opacity="0"
                             Fill="{DynamicResource AccentFillColorDefaultBrush}"
                             RenderTransformOrigin="0.5,0.5"
                             VerticalAlignment="Center">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="AnilloScale" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <ui:Button x:Name="BotonMic" Appearance="Primary"
                               Width="72" Height="72" CornerRadius="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsEnabled="False" Click="BotonMic_Click"
                               ToolTip="Pulsa y habla — se corta solo al callarte">
                        <ui:SymbolIcon Symbol="Mic24" FontSize="28" />
                    </ui:Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
