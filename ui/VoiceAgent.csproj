<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>VozPluma</AssemblyName>
    <RootNamespace>VoiceAgent</RootNamespace>
    <Version>1.2.1</Version>
    <!-- ThemeMode (tema Fluent Win11) está marcado como experimental en .NET 9 -->
    <NoWarn>WPF0001</NoWarn>
    <ApplicationIcon>icono.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WPF-UI" Version="3.0.5" />
  </ItemGroup>

</Project>
