<ui:FluentWindow
    x:Class="VoiceAgent.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Ajustes"
    Width="480" Height="640" ResizeMode="NoResize"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Ajustes" ShowMaximize="False" ShowMinimize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,4,24,8">

                <!-- ================= GENERAL ================= -->
                <TextBlock Text="General" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Micrófono" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="MicCombo" Margin="0,0,0,4" />
                        <TextBlock Text="En automático se elige el primer micrófono real que funcione."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,14"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                        <CheckBox x:Name="EspacioCheck"
                                  Content="Añadir un espacio tras cada frase dictada" />
                        <TextBlock Text="Permite encadenar frases en el modo widget sin que se peguen."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,14"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                        <TextBlock Text="Atajo de teclado global" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="AtajoCombo" Margin="0,0,0,4">
                            <ComboBoxItem Content="Ctrl + Alt + D" Tag="ctrl+alt+d" />
                            <ComboBoxItem Content="Ctrl + Alt + Espacio" Tag="ctrl+alt+space" />
                            <ComboBoxItem Content="F9" Tag="f9" />
                            <ComboBoxItem Content="Desactivado" Tag="" />
                        </ComboBox>
                        <TextBlock Text="Empieza o para el dictado desde cualquier aplicación, sin tocar la ventana ni el widget."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- ================= INICIO ================= -->
                <TextBlock Text="Inicio" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="ArranqueCheck"
                                  Content="Iniciar VozPluma al encender el ordenador" />
                        <TextBlock Text="Se añade al inicio de Windows (solo para tu usuario)."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,14"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                        <CheckBox x:Name="WidgetCheck"
                                  Content="Abrir directamente en modo widget" />
                        <TextBlock Text="Al arrancar, en cuanto el modelo esté listo se muestra el widget flotante en vez de la ventana."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- ================= RENDIMIENTO ================= -->
                <TextBlock Text="Rendimiento" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>

                        <TextBlock Text="Aceleración" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="AcelCombo" Margin="0,0,0,4">
                            <ComboBoxItem Content="Automática (recomendado)" Tag="auto" />
                            <ComboBoxItem Content="GPU NVIDIA (CUDA)" Tag="cuda" />
                            <ComboBoxItem Content="GPU AMD o Intel (DirectML)" Tag="dml" />
                            <ComboBoxItem Content="Solo CPU" Tag="cpu" />
                        </ComboBox>
                        <TextBlock Text="Automática prueba NVIDIA, luego AMD/Intel y por último la CPU. DirectML solo acelera Whisper y necesita instalar el soporte opcional (instalar.bat lo ofrece); Nemotron sin NVIDIA usa la CPU."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,16"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                        <Grid>
                            <TextBlock Text="Duración máxima de grabación" FontSize="13" />
                            <TextBlock x:Name="MaxSegValor" FontSize="13"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <Slider x:Name="MaxSegSlider" Minimum="30" Maximum="600"
                                TickFrequency="30" IsSnapToTickEnabled="True"
                                ValueChanged="Slider_Changed" />
                        <TextBlock Text="Tope de seguridad: normalmente paras tú con el botón. La grabación no se corta al callarte."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,16"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                        <TextBlock Text="Reposo tras inactividad" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="ReposoCombo" Margin="0,0,0,4">
                            <ComboBoxItem Content="A los 5 minutos" Tag="5" />
                            <ComboBoxItem Content="A los 10 minutos" Tag="10" />
                            <ComboBoxItem Content="A los 30 minutos" Tag="30" />
                            <ComboBoxItem Content="Nunca (siempre en memoria)" Tag="0" />
                        </ComboBox>
                        <TextBlock Text="El modelo ocupa varios GB de memoria. En reposo se libera y se vuelve a cargar al pulsar el micrófono o el atajo."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="24,8,24,20">
            <ui:Button Content="Desinstalar…" Appearance="Danger" FontSize="12"
                       HorizontalAlignment="Left" Click="Desinstalar_Click"
                       ToolTip="Elimina los modelos descargados y el entorno de Python" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancelar" Margin="0,0,8,0" Click="Cancelar_Click" />
                <ui:Button Content="Guardar" Appearance="Primary" Click="Guardar_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
