<ui:FluentWindow
    x:Class="VoiceAgent.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Ajustes"
    Width="480" Height="640" ResizeMode="NoResize"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Ajustes" ShowMaximize="False" ShowMinimize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,4,24,8">

                <!-- ================= GENERAL ================= -->
                <TextBlock Text="General" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Micrófono" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="MicCombo" Margin="0,0,0,4" />
                        <TextBlock Text="En automático se elige el primer micrófono real que funcione."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,14"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                        <CheckBox x:Name="EspacioCheck"
                                  Content="Añadir un espacio tras cada frase dictada" />
                        <TextBlock Text="Permite encadenar frases en el modo widget sin que se peguen."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- ================= RENDIMIENTO ================= -->
                <TextBlock Text="Rendimiento" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>

                        <CheckBox x:Name="CpuCheck"
                                  Content="Acelerar con la CPU (equipos sin gráfica NVIDIA)" />
                        <TextBlock Text="Carga el modelo directamente en la CPU usando todos sus núcleos, sin intentar la gráfica. Actívalo si tu PC no tiene GPU NVIDIA o da errores al cargar."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,16"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                        <Grid>
                            <TextBlock Text="Duración máxima de grabación" FontSize="13" />
                            <TextBlock x:Name="MaxSegValor" FontSize="13"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <Slider x:Name="MaxSegSlider" Minimum="30" Maximum="600"
                                TickFrequency="30" IsSnapToTickEnabled="True"
                                ValueChanged="Slider_Changed" />
                        <TextBlock Text="Tope de seguridad: normalmente paras tú con el botón. La grabación no se corta al callarte."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="24,8,24,20">
            <ui:Button Content="Desinstalar…" Appearance="Danger" FontSize="12"
                       HorizontalAlignment="Left" Click="Desinstalar_Click"
                       ToolTip="Elimina los modelos descargados y el entorno de Python" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancelar" Margin="0,0,8,0" Click="Cancelar_Click" />
                <ui:Button Content="Guardar" Appearance="Primary" Click="Guardar_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
