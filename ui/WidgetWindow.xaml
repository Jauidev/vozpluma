<Window
    x:Class="VoiceAgent.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="VozPluma — widget"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    Topmost="True" ShowInTaskbar="False" ShowActivated="False"
    ResizeMode="NoResize" SizeToContent="WidthAndHeight">

    <Border CornerRadius="16" Padding="10,8"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="Arrastrar">
        <StackPanel Orientation="Horizontal">

            <!-- indicador de estado -->
            <Ellipse x:Name="Punto" Width="8" Height="8" Margin="2,0,10,0"
                     VerticalAlignment="Center" Fill="Gray" />

            <ui:Button x:Name="BotonHablar" Appearance="Primary"
                       Width="46" Height="46" CornerRadius="23"
                       Margin="0,0,8,0" Click="Hablar_Click"
                       ToolTip="Empieza a grabar — lo transcrito se escribe donde esté el cursor; pulsa parar cuando termines">
                <ui:SymbolIcon Symbol="Mic24" FontSize="20" />
            </ui:Button>

            <ui:Button x:Name="BotonParar" Appearance="Secondary"
                       Width="40" Height="40" CornerRadius="20"
                       Margin="0,0,8,0" IsEnabled="False" Click="Parar_Click"
                       ToolTip="Detener el dictado">
                <ui:SymbolIcon Symbol="Stop24" FontSize="16" />
            </ui:Button>

            <!-- girando = transcribiendo; desaparece cuando el texto ya está escrito -->
            <ui:ProgressRing x:Name="Progreso" Width="22" Height="22"
                             IsIndeterminate="True" Visibility="Collapsed"
                             Margin="0,0,8,0" VerticalAlignment="Center" />

            <ui:Button x:Name="BotonCerrar" Appearance="Transparent"
                       Width="32" Height="32" CornerRadius="16"
                       VerticalAlignment="Center" Click="Cerrar_Click"
                       ToolTip="Cerrar el widget y volver a la ventana principal">
                <ui:SymbolIcon Symbol="Dismiss24" FontSize="13" />
            </ui:Button>

        </StackPanel>
    </Border>
</Window>
